# ─────────────────────────────────────────────────────────────
# PawPal Pet Care — environment variables
# Copy this file to `.env.local` and fill in your real values.
# `.env.local` is git-ignored, so your secrets stay safe.
# ─────────────────────────────────────────────────────────────

# Supabase project URL & anon (public) key.
# Find these in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-anon-public-key

# The provider's email (that's YOU). Anyone who signs up with this email
# is automatically given the "provider" role. Everyone else is a "customer".
NEXT_PUBLIC_PROVIDER_EMAIL=edesane4@gmail.com

# ── Server-only secrets (NOT exposed to the browser) ──
# Used by Edge Functions / server routes. Keep these private!
# Find the service-role key in: Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=YOUR-service-role-key

# Optional: Google Calendar sync (see supabase/functions/notify-booking).
# Create an OAuth client or service account in Google Cloud Console.
GOOGLE_CALENDAR_ID=primary
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Optional: Web Push (VAPID) keys for browser push notifications to your phone.
# Generate with:  npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ── Calendar sync (Skylight / Apple / Google) ──
# Flow 1 — subscribable feed of your bookings. Pick any long random string;
# your private feed URL becomes:  <site>/api/calendar/<CALENDAR_FEED_TOKEN>
# Subscribe to that URL in Skylight and/or Apple Calendar.
CALENDAR_FEED_TOKEN=

# Flow 2 — black out times you're busy. Paste the PUBLIC .ics URL of the
# calendar that holds your real availability (e.g. an iCloud "Public Calendar"
# link, or a Google "Secret address in iCal format"). webcal:// is fine.
PROVIDER_BUSY_ICS_URL=
